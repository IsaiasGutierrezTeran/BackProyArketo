# ──────────────────────────────────────────────────────────────────────────────
# REFERENCIA del .env que deploy.sh GENERA AUTOMÁTICAMENTE en la EC2.
# No necesitas crear este archivo: deploy.sh lo arma con la IP/cuenta reales,
# genera DJANGO_SECRET_KEY y la clave de Postgres, y lo deja SOLO en la instancia
# (en /opt/arketo/.env). Aquí solo se documenta qué consume el stack.
# Los valores con <…> los rellena deploy.sh.
# ──────────────────────────────────────────────────────────────────────────────

# Imágenes en ECR (las arma deploy.sh)
ECR_BACKEND=<acct>.dkr.ecr.us-east-1.amazonaws.com/arketo/backend:latest
ECR_FLOORAPI=<acct>.dkr.ecr.us-east-1.amazonaws.com/arketo/floorapi:latest
ECR_MASKRCNN=<acct>.dkr.ecr.us-east-1.amazonaws.com/arketo/maskrcnn:latest

# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=<generado>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=<ip-guiones>.sslip.io,<ip>,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://<ip-guiones>.sslip.io,http://<ip>
CORS_ALLOWED_ORIGINS=https://tu-front.vercel.app,http://localhost:4200
PUBLIC_BASE_URL=https://<ip-guiones>.sslip.io

# Postgres (interno, sin puerto expuesto)
POSTGRES_DB=arketo
POSTGRES_USER=arketo
POSTGRES_PASSWORD=<generado>
DATABASE_URL=postgres://arketo:<generado>@db:5432/arketo

# Almacenamiento S3 (bucket privado + rol IAM de la EC2, SIN claves)
USE_S3=true
AWS_STORAGE_BUCKET_NAME=arketo-docs-<acct>-us-east-1
AWS_S3_REGION_NAME=us-east-1
AWS_REGION=us-east-1
AWS_QUERYSTRING_AUTH=true

# Detección 2D->3D: Mask R-CNN real (Django -> floorapi -> maskrcnn)
DETECTION_DEFAULT_DETECTOR=maskrcnn
FLOORPLAN_API_URL=http://floorapi:8000
FLOORPLAN_API_TIMEOUT=180
MASKRCNN_LEGACY_URL=http://maskrcnn:5000/

# IA del backend con AWS (NO Gemini)
AI_DESIGN_PROVIDER=aws
RISK_ANALYZER=aws
SPEECH_TO_TEXT_PROVIDER=aws
SKETCH_PROVIDER=mock
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
TRANSCRIBE_LANGUAGE=es-US

# Caddy (HTTPS sslip.io)
SSLIP_DOMAIN=<ip-guiones>.sslip.io
