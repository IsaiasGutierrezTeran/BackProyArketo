# ---------------------------------------------------------------------------
# Arketo — Django backend. Copy to `.env` and adjust.
# Read at startup by config/settings/base.py. Nothing here is hard-coded.
# ---------------------------------------------------------------------------

# --- Core -------------------------------------------------------------------
# Generate for prod: python -c "import secrets;print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Pick the settings module: config.settings.dev | config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Database (PostgreSQL — REQUIRED, no sqlite fallback) -------------------
# Local host run against the docker postgres:        @localhost:${DB_HOST_PORT}
# From inside the web container (docker-compose):     @db:5432
DATABASE_URL=postgres://arketo:arketo@localhost:5432/arketo
# If you already have a local Postgres on 5432, publish the container elsewhere:
#   DB_HOST_PORT=55432   (and set DATABASE_URL host port to match)
DB_HOST_PORT=5432

# Used by docker-compose to provision the postgres container:
POSTGRES_DB=arketo
POSTGRES_USER=arketo
POSTGRES_PASSWORD=arketo

# --- JWT --------------------------------------------------------------------
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- CORS (Angular web; Flutter native ignores CORS) -----------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- Media / absolute file URLs --------------------------------------------
# Empty -> derived from the request. In prod set the public URL, e.g.
# https://api.arketo.com  (so mobile gets absolute, reachable file URLs)
PUBLIC_BASE_URL=
MAX_UPLOAD_SIZE_MB=20

# --- File storage: local (default) or S3 / MinIO ---------------------------
# USE_S3=false -> archivos en disco (MEDIA_ROOT). USE_S3=true -> S3/MinIO.
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=arketo-media
AWS_S3_REGION_NAME=us-east-1
# Para AWS real deja vacío. Para MinIO local: http://localhost:9000
AWS_S3_ENDPOINT_URL=
AWS_S3_USE_SSL=true
# MinIO requiere 'path'; AWS real puede usar 'auto'
AWS_S3_ADDRESSING_STYLE=auto
# false = URLs públicas sin firmar (visor 3D/móvil las cargan directo)
AWS_QUERYSTRING_AUTH=false
# Ejemplo MinIO local:
#   USE_S3=true  AWS_ACCESS_KEY_ID=minioadmin  AWS_SECRET_ACCESS_KEY=minioadmin
#   AWS_STORAGE_BUCKET_NAME=arketo-media  AWS_S3_ENDPOINT_URL=http://localhost:9000
#   AWS_S3_USE_SSL=false  AWS_S3_ADDRESSING_STYLE=path

# --- Seeders (dev only) -----------------------------------------------------
SEED_ADMIN_PASSWORD=Admin12345
SEED_DEMO_PASSWORD=Demo12345

# --- Integrations (later sprints) ------------------------------------------
# floorplan-api corre en :8001 (Django usa :8000) — ver run_floorplan.ps1.
FLOORPLAN_API_URL=http://127.0.0.1:8001
FLOORPLAN_API_TIMEOUT=120
GEMINI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# HU-18 Boceto 2D por prompt (IA): mock (sin clave) | gemini
SKETCH_PROVIDER=mock
